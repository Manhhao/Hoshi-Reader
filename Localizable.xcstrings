          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un **[projet Google Cloud](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** est nécessaire pour la synchronisation."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È necessario un **[progetto Google Cloud](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** per la sincronizzazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期には **[Google Cloud プロジェクト](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동기화에는 **[Google Cloud 프로젝트](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)**가 필요합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een **[Google Cloud-project](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** is vereist voor synchronisatie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um **[projeto Google Cloud](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** é necessário para sincronização."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для синхронизации необходим **[проект Google Cloud](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)**."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Senkronizasyon için bir **[Google Cloud projesi](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** gereklidir."
          }
