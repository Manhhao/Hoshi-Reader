    "This will download the latest versions of the following dictionaries (22 MB):\nJMdict (Term)\nJiten (Frequency)": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将下载以下词典的最新版本（22 MB）：\nJMdict（术语）\nJiten（频率）"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم تنزيل أحدث إصدارات القواميس التالية (22 ميغابايت):\nJMdict (مصطلحات)\nJiten (تردد)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies lädt die neuesten Versionen folgender Wörterbücher herunter (22 MB):\nJMdict (Begriffe)\nJiten (Häufigkeit)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se descargarán las últimas versiones de los siguientes diccionarios (22 MB):\nJMdict (Términos)\nJiten (Frecuencia)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci téléchargera les dernières versions des dictionnaires suivants (22 Mo) :\nJMdict (Termes)\nJiten (Fréquence)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verranno scaricate le ultime versioni dei seguenti dizionari (22 MB):\nJMdict (Termini)\nJiten (Frequenza)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "以下の辞書の最新版をダウンロードします（22 MB）：\nJMdict（用語）\nJiten（頻度）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 사전의 최신 버전을 다운로드합니다 (22 MB):\nJMdict (용어)\nJiten (빈도)"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit downloadt de nieuwste versies van de volgende woordenboeken (22 MB):\nJMdict (Termen)\nJiten (Frequentie)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso baixará as versões mais recentes dos seguintes dicionários (22 MB):\nJMdict (Termos)\nJiten (Frequência)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Будут загружены последние версии следующих словарей (22 МБ):\nJMdict (Термины)\nJiten (Частотность)"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aşağıdaki sözlüklerin en son sürümleri indirilecek (22 MB):\nJMdict (Terim)\nJiten (Sıklık)"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sẽ tải phiên bản mới nhất của các từ điển sau (22 MB):\nJMdict (Thuật ngữ)\nJiten (Tần suất)"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將下載以下辭典的最新版本（22 MB）：\nJMdict（術語）\nJiten（頻率）"
          }
        }
      }
    },
    "This will check for and install updates for these dictionaries:\n%@": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将检查并安装以下词典的更新：\n%@"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم التحقق من تحديثات هذه القواميس وتثبيتها:\n%@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies prüft und installiert Updates für diese Wörterbücher:\n%@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se comprobarán e instalarán actualizaciones para estos diccionarios:\n%@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci vérifiera et installera les mises à jour de ces dictionnaires :\n%@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verranno verificati e installati aggiornamenti per questi dizionari:\n%@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "以下の辞書の更新を確認しインストールします：\n%@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 사전의 업데이트를 확인하고 설치합니다:\n%@"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit controleert en installeert updates voor deze woordenboeken:\n%@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso verificará e instalará atualizações para estes dicionários:\n%@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Будет выполнена проверка и установка обновлений для этих словарей:\n%@"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu sözlükler için güncellemeler kontrol edilip yüklenecek:\n%@"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sẽ kiểm tra và cài đặt cập nhật cho các từ điển này:\n%@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將檢查並安裝以下辭典的更新：\n%@"
          }
        }
      }
    },
    "This will replace AnkiMobile callbacks with AnkiConnect requests.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将用 AnkiConnect 请求替代 AnkiMobile 回调。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيستبدل هذا استدعاءات AnkiMobile بطلبات AnkiConnect."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies ersetzt AnkiMobile-Callbacks durch AnkiConnect-Anfragen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto reemplazará las devoluciones de AnkiMobile con solicitudes AnkiConnect."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci remplacera les rappels AnkiMobile par des requêtes AnkiConnect."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo sostituirà i callback di AnkiMobile con richieste AnkiConnect."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AnkiMobile のコールバックを AnkiConnect リクエストに置き換えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AnkiMobile 콜백을 AnkiConnect 요청으로 교체합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit vervangt AnkiMobile-callbacks door AnkiConnect-verzoeken."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso substituirá os callbacks do AnkiMobile por solicitações AnkiConnect."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это заменит обратные вызовы AnkiMobile на запросы AnkiConnect."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, AnkiMobile geri çağırmalarını AnkiConnect istekleriyle değiştirecektir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ thay thế callback AnkiMobile bằng yêu cầu AnkiConnect."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將以 AnkiConnect 請求取代 AnkiMobile 回呼。"
          }
        }
      }
    },
