    "A **[Google Cloud project](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** is necessary for syncing.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同步需要一个 **[Google Cloud 项目](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)**。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يلزم **[مشروع Google Cloud](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** للمزامنة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein **[Google Cloud-Projekt](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** ist für die Synchronisation erforderlich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
