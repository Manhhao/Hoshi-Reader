    "AnkiMobile or a hosted AnkiConnect instance is required to mine words.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要 AnkiMobile 或 AnkiConnect 实例才能制卡。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يلزم AnkiMobile أو نسخة AnkiConnect لإنشاء البطاقات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "AnkiMobile oder eine AnkiConnect-Instanz wird zum Erstellen von Karten benötigt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita AnkiMobile o una instancia de AnkiConnect para crear tarjetas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "AnkiMobile ou une instance AnkiConnect est nécessaire pour créer des cartes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È necessario AnkiMobile o un'istanza AnkiConnect per creare schede."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "単語を登録するには AnkiMobile または AnkiConnect が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단어를 등록하려면 AnkiMobile 또는 AnkiConnect 인스턴스가 필요합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "AnkiMobile of een AnkiConnect-instantie is vereist om kaarten te maken."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "É necessário o AnkiMobile ou uma instância do AnkiConnect para criar cartões."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для создания карточек необходим AnkiMobile или экземпляр AnkiConnect."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kart oluşturmak için AnkiMobile veya bir AnkiConnect örneği gereklidir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cần AnkiMobile hoặc phiên bản AnkiConnect để tạo thẻ."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "需要 AnkiMobile 或 AnkiConnect 實例才能製卡。"
          }
        }
      }
    },
