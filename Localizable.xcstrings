    "Import a local audio database for offline dictionary audio. The local audio source is automatically added when enabled.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入本地音频数据库以供离线词典音频使用。启用后会自动添加本地音频来源。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استيراد قاعدة بيانات صوتية محلية للصوت دون اتصال. يُضاف مصدر الصوت المحلي تلقائيًا عند التفعيل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Importieren Sie eine lokale Audiodatenbank für Offline-Wörterbuchaudio. Die lokale Audioquelle wird bei Aktivierung automatisch hinzugefügt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importe una base de datos de audio local para audio sin conexión. La fuente de audio local se añade automáticamente al activar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importez une base audio locale pour l'audio hors ligne. La source audio locale est ajoutée automatiquement à l'activation."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa un database audio locale per l'audio offline. La fonte audio locale viene aggiunta automaticamente all'attivazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフライン辞書音声用にローカル音声データベースをインポートします。有効にすると自動的にローカル音声ソースが追加されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오프라인 사전 오디오용 로컬 오디오 데이터베이스를 가져옵니다. 활성화하면 로컬 오디오 소스가 자동으로 추가됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Importeer een lokale audiodatabase voor offline woordenboekaudio. De lokale audiobron wordt automatisch toegevoegd bij inschakeling."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Importe um banco de dados de áudio local para áudio offline. A fonte de áudio local é adicionada automaticamente ao ativar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Импортируйте локальную аудиобазу для офлайн-аудио словаря. Локальный источник аудио добавляется автоматически при включении."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çevrimdışı sözlük sesi için yerel ses veritabanı içe aktarın. Etkinleştirildiğinde yerel ses kaynağı otomatik olarak eklenir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhập cơ sở dữ liệu âm thanh cục bộ cho từ điển ngoại tuyến. Nguồn âm thanh cục bộ sẽ tự động được thêm khi bật."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入本地音訊資料庫以供離線辭典音訊使用。啟用後會自動加入本地音訊來源。"
          }
        }
      }
    },
