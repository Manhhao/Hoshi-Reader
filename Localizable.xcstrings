    "Sync bookmarks and statistics with ッツ Reader or between Hoshi Reader devices via Google Drive.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 Google Drive 与 ッツ Reader 或 Hoshi Reader 设备之间同步书签和统计数据。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مزامنة الإشارات المرجعية والإحصائيات مع ッツ Reader أو بين أجهزة Hoshi Reader عبر Google Drive."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronisieren Sie Lesezeichen und Statistiken mit ッツ Reader oder zwischen Hoshi Reader-Geräten über Google Drive."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincronice marcadores y estadísticas con ッツ Reader o entre dispositivos Hoshi Reader a través de Google Drive."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronisez les signets et statistiques avec ッツ Reader ou entre appareils Hoshi Reader via Google Drive."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincronizza segnalibri e statistiche con ッツ Reader o tra dispositivi Hoshi Reader tramite Google Drive."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Google Drive を使って ッツ Reader や Hoshi Reader デバイス間でブックマークと統計を同期します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Google Drive를 통해 ッツ Reader 또는 Hoshi Reader 기기 간에 북마크와 통계를 동기화합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchroniseer bladwijzers en statistieken met ッツ Reader of tussen Hoshi Reader-apparaten via Google Drive."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincronize marcadores e estatísticas com o ッツ Reader ou entre dispositivos Hoshi Reader via Google Drive."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Синхронизируйте закладки и статистику с ッツ Reader или между устройствами Hoshi Reader через Google Drive."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Google Drive aracılığıyla ッツ Reader veya Hoshi Reader cihazları arasında yer imlerini ve istatistikleri senkronize edin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đồng bộ dấu trang và thống kê với ッツ Reader hoặc giữa các thiết bị Hoshi Reader qua Google Drive."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透過 Google Drive 與 ッツ Reader 或 Hoshi Reader 裝置之間同步書籤和統計資料。"
          }
        }
      }
    },
