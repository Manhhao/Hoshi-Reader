            "value": "Cần một **[dự án Google Cloud](https://github.com/ttu-ttu/ebook-reader?tab=readme-ov-file#storage-sources)** để đồng bộ."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
