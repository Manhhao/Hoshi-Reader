    "Determines if statistics will be merged entry by entry or replaced completely on a sync.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "决定同步时统计数据是逐条合并还是完全替换。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحدد ما إذا كانت الإحصائيات ستُدمج عنصرًا بعنصر أو تُستبدل بالكامل عند المزامنة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bestimmt, ob Statistiken bei der Synchronisation eintragsweise zusammengeführt oder vollständig ersetzt werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Determina si las estadísticas se fusionan entrada por entrada o se reemplazan completamente al sincronizar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Détermine si les statistiques seront fusionnées entrée par entrée ou remplacées complètement lors d'une synchronisation."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Determina se le statistiche verranno unite voce per voce o sostituite completamente durante la sincronizzazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期時に統計データを項目ごとに結合するか完全に置換するかを決定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동기화 시 통계를 항목별로 병합할지 완전히 교체할지 결정합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bepaalt of statistieken per item worden samengevoegd of volledig worden vervangen bij synchronisatie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Determina se as estatísticas serão mescladas entrada por entrada ou substituídas completamente na sincronização."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Определяет, будет ли статистика объединяться поэлементно или полностью заменяться при синхронизации."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Senkronizasyonda istatistiklerin girdi girdi birleştirilip birleştirilmeyeceğini veya tamamen değiştirilip değiştirilmeyeceğini belirler."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xác định liệu thống kê sẽ được gộp từng mục hay thay thế hoàn toàn khi đồng bộ."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "決定同步時統計資料是逐條合併還是完全替換。"
          }
        }
      }
    },
